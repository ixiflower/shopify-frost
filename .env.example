# Required: Your Shopify store domain (e.g., my-store.myshopify.com)
PUBLIC_STORE_DOMAIN=""
# Required: Your Shopify Storefront API public token
PUBLIC_STOREFRONT_API_TOKEN=""
# Required: Your Shopify Storefront API version (e.g., 2026-07)
PUBLIC_STOREFRONT_API_VERSION=""
# Required: Your Shopify Storefront API private token (server-only)
PRIVATE_STOREFRONT_API_TOKEN=""
# Required: A random string used to sign session cookies
SESSION_SECRET=""
# Optional: Your Shopify checkout domain (defaults to PUBLIC_STORE_DOMAIN)
PUBLIC_CHECKOUT_DOMAIN=""
